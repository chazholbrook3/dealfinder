# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio (get from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # your Twilio phone number
BROKER_PHONE=+1XXXXXXXXXX         # broker's real phone to receive alerts

# Broker info (used in AI-generated messages)
BROKER_NAME=Mike Carter
BROKER_PHONE_DISPLAY=(435) 555-0199

# App secret key (generate any random string)
SECRET_KEY=change-me-to-something-random

# Scan interval in minutes (how often to check KSL)
SCAN_INTERVAL_MINUTES=15

# Mannheim MMR API (Cox Automotive developer portal)
MANNHEIM_CLIENT_ID=your_client_id
MANNHEIM_CLIENT_SECRET=your_client_secret
